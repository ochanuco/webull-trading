{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "webull-trading",
  "main": "src/index.ts",
  "compatibility_date": "2025-10-01",
  "observability": {
    "enabled": true
  },
  "env": {
    "staging": {
      "name": "webull-trading-staging"
    },
    "production": {
      "name": "webull-trading-production"
    }
  }
}
